{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noEmitOnError": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@org-agent-skills/config": ["packages/config/src/index.ts"],
      "@org-agent-skills/core": ["packages/core/src/index.ts"],
      "@org-agent-skills/adapters": ["packages/adapters/src/index.ts"],
      "@org-agent-skills/testkit": ["packages/testkit/src/index.ts"]
    },
    "lib": ["ES2023"]
  }
}
